# ══════════════════════════════════════════════════════════════════
# AutoMail Pipeline — environment variables
# Copy this file to .env and fill in real values.
# .env is .gitignored; never commit real keys.
# ══════════════════════════════════════════════════════════════════

# ── AI providers ───────────────────────────────────────────────────
# https://console.anthropic.com/
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY

# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Google workspace ───────────────────────────────────────────────
# Sheet ID is the long string in the Sheets URL after /d/
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# Apps Script Web App URL (from Deploy → New deployment → Web app)
APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# OAuth 2.0 client (used by the Chrome extension + Python extractor)
GOOGLE_OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GCP_PROJECT_NUMBER=YOUR_GCP_PROJECT_NUMBER

# ── Enrichment providers (optional, Android app) ───────────────────
APOLLO_API_KEY=YOUR_APOLLO_API_KEY
ROCKETREACH_API_KEY=YOUR_ROCKETREACH_API_KEY
HUNTER_API_KEY=YOUR_HUNTER_API_KEY

# ── Proxy (optional, Chrome extension) ─────────────────────────────
BRIGHTDATA_API_KEY=YOUR_BRIGHTDATA_API_KEY

# ── Sender identity ────────────────────────────────────────────────
SENDER_EMAIL=your.email@example.com
SENDER_NAME=Your Name
SENDER_LINKEDIN=https://www.linkedin.com/in/your-handle

# ── Resume Drive IDs (set once; Apps Script auto-discovers by filename) ──
RESUME_DRIVE_ID_GROWTH=YOUR_DRIVE_FILE_ID
RESUME_DRIVE_ID_OPS=YOUR_DRIVE_FILE_ID
RESUME_DRIVE_ID_PRODUCT=YOUR_DRIVE_FILE_ID
